rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Сообщества — читать всем, писать только авторизованным
    match /communities/{communityId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.ownerId == request.auth.uid
            || request.auth.token.email == 'dollmanb1337@gmail.com');
      allow delete: if request.auth != null
        && (resource.data.ownerId == request.auth.uid
            || request.auth.token.email == 'dollmanb1337@gmail.com');
    }

    // Участники сообществ
    match /community_members/{communityId}/members/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Сообщества пользователя — только свои
    match /user_communities/{userId}/communities/{communityId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Посты в сообществах
    match /community_posts/{communityId}/posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid;
      allow delete: if request.auth != null
        && (resource.data.authorId == request.auth.uid
            || request.auth.token.email == 'dollmanb1337@gmail.com');
      allow update: if request.auth != null;
    }

    // Запросы на вступление
    match /community_requests/{communityId}/requests/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Комментарии к постам
    match /post_comments/{communityId}/posts/{postId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid;
      allow delete: if request.auth != null
        && (resource.data.authorId == request.auth.uid
            || request.auth.token.email == 'dollmanb1337@gmail.com');
    }

    // Запросы верификации сообществ
    match /community_verifications/{communityId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
