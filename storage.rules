rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Правила для аватарок
    match /avatars/{userId}/{allPaths=**} {
      // Разрешаем чтение всем
      allow read;
      
      // Разрешаем запись только владельцу
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Ограничение размера (максимум 5MB)
      allow create: if request.resource.size < 5 * 1024 * 1024
                       && request.resource.contentType.matches('image/.*');
    }
    
    // Правила для фонов
    match /backgrounds/{userId}/{allPaths=**} {
      // Разрешаем чтение всем
      allow read;
      
      // Разрешаем запись только владельцу
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Ограничение размера (максимум 10MB)
      allow create: if request.resource.size < 10 * 1024 * 1024
                       && request.resource.contentType.matches('image/.*');
    }
    
    // Общие правила для всех остальных файлов
    match /{allPaths=**} {
      // Разрешаем чтение всем
      allow read;
      
      // Запрещаем запись без аутентификации
      allow write: if false;
    }
  }
}