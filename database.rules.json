{
  "rules": {

    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid == $uid",

        "badges": {
          ".read": "auth != null",
          ".write": "auth != null && (auth.uid == $uid || auth.token.email == 'dollmanb1337@gmail.com')"
        },
        "banned": {
          ".read": "auth != null",
          ".write": "auth != null && auth.token.email == 'dollmanb1337@gmail.com'"
        },
        "banReason": {
          ".read": "auth != null",
          ".write": "auth != null && auth.token.email == 'dollmanb1337@gmail.com'"
        },
        "bannedAt":  { ".write": "auth != null && auth.token.email == 'dollmanb1337@gmail.com'" },
        "bannedBy":  { ".write": "auth != null && auth.token.email == 'dollmanb1337@gmail.com'" },
        "premium":   { ".write": "auth != null && auth.token.email == 'dollmanb1337@gmail.com'" }
      }
    },

    "nicknames_index": {
      ".read": "auth != null",
      "$key": {
        ".write": "auth != null"
      }
    },

    "emails_index": {
      ".read": "auth != null",
      "$key": {
        ".write": "auth != null"
      }
    },

    "pending_verification": {
      "$tempId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "community_verifications": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
